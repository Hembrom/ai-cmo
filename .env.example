# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google PageSpeed Insights (optional – omit to skip perf data)
GOOGLE_PAGESPEED_KEY=

# Restrict CORS to your frontend origin in production
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# Vercel Postgres (auto-injected when you link a Vercel Postgres DB)
POSTGRES_URL=postgres://user:password@host/database?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://user:password@host/database?sslmode=require
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
