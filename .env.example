# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Google PageSpeed Insights (optional – omit to skip perf data)
GOOGLE_PAGESPEED_KEY=

# Restrict CORS to your frontend origin in production
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# Supabase / Postgres connection
POSTGRES_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
POSTGRES_USER=postgres
POSTGRES_HOST=db.YOUR_REF.supabase.co
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DATABASE=postgres

# Meta (Facebook + Instagram) OAuth
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
BASE_URL=https://your-domain.com

# JWT authentication
JWT_SECRET=your_jwt_secret_min_32_chars
